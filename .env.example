# ============================================================
# AutoMerge — Environment Variables Template
# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแทนที่ค่าทั้งหมดด้วยค่าจริงของคุณ
# ห้าม Commit ไฟล์ .env จริงขึ้น Git เด็ดขาด
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/automerge_raw

# --- Security ---
# สร้าง SECRET_KEY ด้วยคำสั่ง: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_64_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Upload ---
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=temp_uploads

# --- CORS (คั่นหลาย Origin ด้วย comma) ---
# Local Dev:
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
# Production: เปลี่ยนเป็น Domain จริง เช่น
# ALLOWED_ORIGINS=https://app.yourdomain.com
